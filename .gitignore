# Build artifacts and local generated files (not source of truth)
cuda/lib/
tests/bin/
third_party/
*.o
*.so
env.sh
__pycache__/
*.pyc

# Compiled tool/check binaries land in a per-directory bin/ folder so new tools need no
# per-binary .gitignore entry (the build scripts -o into bin/; only the .cpp/.cu/.sh are source).
tools/bin/
cuda/tools/bin/

# Subdir tools whose binary sits next to its own data/ (run cwd-relative), kept in place:
tools/decode_graph/decode_graph
tools/qwen3/run_qwen3
tools/qwen35/run_gdn
tools/qwen35/run_qwen35

# Exported model-weight fixtures (regenerated by export_qwen3.py / export_qwen35.py via the build_*.sh scripts; large binary, not source)
tools/qwen3/data/
tools/qwen35/data_full/
tools/qwen35/data_gdn/
